{
  "name": "tasks-gcal-sync",
  "version": "0.3.0",
  "description": "Sync Obsidian Tasks to Google Calendar (all-day events, two-way, #done prefix).",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version-bump": "node version-bump.mjs"
  },
  "keywords": [
    "obsidian",
    "tasks",
    "google-calendar"
  ],
  "author": "Moon",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.2",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  }
}
